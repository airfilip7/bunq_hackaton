# AWS / Bedrock
AWS_REGION=us-east-1
BEDROCK_VISION_MODEL=us.anthropic.claude-sonnet-4-6
BEDROCK_CHAT_MODEL=us.anthropic.claude-sonnet-4-6

# bunq
BUNQ_MODE=sandbox
# Use POST /v1/sandbox-user-person to generate one
BUNQ_API_KEY=
BUNQ_BASE_URL=https://public-api.sandbox.bunq.com/v1
BUNQ_SANDBOX=true

# Storage
STORAGE_BACKEND=sqlite
SQLITE_PATH=/tmp/bunq_nest.db

# Auth
JWT_SECRET=
DEMO_USER_ID=u_demo

# Funda
FUNDA_MODE=fixture

# Demo
DEMO_REPLAY=0
